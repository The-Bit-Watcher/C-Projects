digraph "Graphical Class Hierarchy"
{
 // LATEX_PDF_SIZE
  edge [fontname="Helvetica",fontsize="10",labelfontname="Helvetica",labelfontsize="10"];
  node [fontname="Helvetica",fontsize="10",shape=record];
  rankdir="LR";
  Node0 [label="NotificationObserver",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classNotificationObserver.html",tooltip="Observer interface for notification recipients."];
  Node0 -> Node1 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node1 [label="UserNotificationObserver",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classUserNotificationObserver.html",tooltip="Concrete observer for user notifications."];
}
